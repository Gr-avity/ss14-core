ent-BaseCharon280mmCartridge = base 280mm Charybdis cartridge
    .desc = { ent-BaseItem.desc }
ent-CartridgeCharon280mmSlug = M381 CHARYBDIS 280mm 26.5kg slug
    .desc = A 26.5 kilogram depleted-tungsten penetrator round for the M321-CHARYBDIS 'Thanatos' railgun system. The slug punches through multiple targets and structural layers before its delayed fuse detonates. Handle with extreme care. Requires manual chamber loading.
    .suffix = Slug
ent-CartridgeCharon280mmSubnuclear = M381 CHARYBDIS 280mm 40kg subnuclear slug
    .desc = A 40 kilogram subnuclear warhead packaged as a railgun slug for the M321-CHARYBDIS 'Thanatos' system. Detonates on first contact, producing a massive subnuclear detonation with significant residual radiation. RESTRICTED to authorized combat operations only. Requires manual chamber loading.
    .suffix = Subnuclear
ent-BaseDravon75mmShell = base 75mm Dravon shell
    .desc = { ent-BaseItem.desc }
ent-CartridgeDravon75mmHE = DVN-75 75mm HE shell
    .desc = A 75mm high-explosive artillery shell for the Dravon cannon system. Detonates on impact with a solid area-of-effect blast.
    .suffix = HE
ent-MagazineDravon75mmHE = DVN-75 75mm HE shell magazine
    .desc = A 15-round magazine of 75mm HE shells for the Dravon cannon system.
ent-BaseAK570_90mmShell = base 90mm AK570 shell
    .desc = { ent-BaseItem.desc }
ent-CartridgeAK570_90mmHE = AK-90 90mm HE shell
    .desc = A 90mm high-explosive artillery shell for the AK570 cannon system. Heavier than the Dravon's 75mm round, with a larger explosive yield.
    .suffix = HE
ent-MagazineAK570_90mmHE = AK-90 90mm HE shell magazine
    .desc = A 20-round magazine of 90mm HE shells for the AK570 cannon system.
ent-BaseLeviathan240mmShell = base 240mm Leviathan shell
    .desc = { ent-BaseItem.desc }
ent-CartridgeLeviathan240mmHE = LVT-240 240mm HE artillery shell
    .desc = A massive 240mm high-explosive artillery shell for the Leviathan siege cannon. The sheer concussive force of detonation can level structures and devastate entire sections of a ship. Requires manual chamber loading.
    .suffix = HE

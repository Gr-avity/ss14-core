ent-DisposalPipeBase = { "" }
    .desc = { "" }
ent-DisposalHolder = держатель утилизационного блока
    .desc = { "" }
ent-DisposalPipeBroken = поврежденная утилизационная труба
    .desc = A BBP (big broken pipe).
ent-DisposalPipe = участок утилизационной трубы
    .desc = A huge pipe segment used for constructing disposal systems.
ent-DisposalTagger = маркировщик утилизационной трубы
    .desc = A pipe that tags entities for routing.
ent-DisposalSignaller = сигнализатор утилизации
    .desc = A pipe that emits a signal when in item goes through it.
ent-DisposalTrunk = ствол утилизационной трубы
    .desc = A pipe trunk used as an entry point for disposal systems.
ent-DisposalRouter = маршрутизатор утилизационной трубы
    .desc = A disposal pipe able to filter items based on a tag. Items coming from the exits are not filtered and sent to the entrance instead.
